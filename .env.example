# Supabase public browser configuration. Vite supports these local names.
# On Vercel, vite.config.ts maps the connected integration's NEXT_PUBLIC_* names.
VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy fallback if your project still uses an anon key:
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (scripts/seed-supabase.js). NEVER prefixed with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
